<group name="local,sshd,authentication">

  <!-- SSH Brute Force Detection -->
  <rule id="100001" level="10" frequency="5" timeframe="60">
    <if_matched_sid>5710</if_matched_sid>
    <description>SSH Brute Force Attack: Multiple failed login attempts detected</description>
    <mitre>
      <id>T1110.001</id>
    </mitre>
    <group>authentication_failures,pci_dss_10.2.4,pci_dss_10.2.5</group>
  </rule>

  <!-- Credential File Access -->
  <rule id="100002" level="12">
    <if_sid>5501</if_sid>
    <match>/etc/shadow</match>
    <description>Suspicious access to /etc/shadow - Possible credential dumping</description>
    <mitre>
      <id>T1003.008</id>
    </mitre>
    <group>credential_access</group>
  </rule>

  <!-- Atomic Red Team Detection -->
  <rule id="100003" level="8">
    <if_sid>5501</if_sid>
    <match>art.sh</match>
    <description>Atomic Red Team script execution detected in /tmp</description>
    <mitre>
      <id>T1059.004</id>
    </mitre>
    <group>attack_simulation</group>
  </rule>

</group>
